LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Gemini TTS is mocked by default so local tests and scenarios do not need credentials.
GEMINI_TTS_MOCK=1
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE=Kore

# Optional knobs
INTERACTION_JUDGE_INTERVAL_MS=500
EVENTS_JSONL_PATH=livekit_interaction_model_demo/events.jsonl

# Optional LiveKit Inference STT for real audio transcription in agent_worker.py.
# Leave empty when using text-only room input or the scripted browser demo.
LIVEKIT_STT_MODEL=
LIVEKIT_STT_LANGUAGE=multi
